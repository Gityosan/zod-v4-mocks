{
  "name": "zod-v4-mocks",
  "version": "3.0.0",
  "type": "module",
  "license": "MIT",
  "private": false,
  "description": "Mock generator for zod v4",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Gityosan/zod-v4-mocks.git"
  },
  "author": {
    "name": "IIHARA議長",
    "url": "https://x.com/iihara_gityo"
  },
  "keywords": [
    "zod",
    "zod-v4",
    "zod-v4-preview-mocks",
    "faker",
    "randexp",
    "mock",
    "generator"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    }
  },
  "bin": {
    "zod-v4-mocks": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "pnpm run build",
    "doc:dev": "pnpm -C docs run dev"
  },
  "files": [
    "dist"
  ],
  "packageManager": "pnpm@10.7.1",
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "dependencies": {
    "@faker-js/faker": "10.3.0",
    "c12": "4.0.0-beta.4",
    "citty": "0.2.2",
    "consola": "3.4.2",
    "es-toolkit": "1.45.1",
    "jiti": "2.7.0",
    "log-update": "7.2.0",
    "randexp": "0.5.3"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/node": "25.4.0",
    "@typescript-eslint/eslint-plugin": "8.57.0",
    "@typescript-eslint/parser": "8.57.0",
    "eslint": "10.0.3",
    "prettier": "3.8.1",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.0.18",
    "zod": "4.3.6"
  }
}
